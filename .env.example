# ============================================================
# Настройки Azure DevOps Team Productivity Analytics
# ============================================================
# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# ВАРИАНТ 1: Azure DevOps Services (облако, dev.azure.com)
# ------------------------------------------------------------

# URL вашей организации в Azure DevOps (облако)
# Формат: https://dev.azure.com/<ваш-org>
ADO_SERVER_URL=https://dev.azure.com/your-organization

# Personal Access Token (PAT) для аутентификации.
# Как создать: dev.azure.com → User Settings (иконка вверху справа)
#              → Personal access tokens → New Token
#
# Права для main.py (только чтение):
#   Code (Read) | Work Items (Read)
#
# Права для setup_test_data.py (запись тестовых данных):
#   Code (Read & Write) | Work Items (Read, Write & Manage)
#   Примечание: создание проекта требует прав администратора организации.
#   Если проект "TeamProductivityTest" создать вручную заранее —
#   дополнительные права не нужны.
ADO_PAT=your-personal-access-token-here

# ------------------------------------------------------------
# ВАРИАНТ 2: Azure DevOps Server (on-premises)
# ------------------------------------------------------------
# URL сервера Azure DevOps (on-prem)
# Формат: https://tfs.company.local/tfs  или  http://ado-server:8080/tfs
# ADO_SERVER_URL=https://tfs.company.local/tfs

# PAT для on-premises аналогично облачному варианту,
# либо используйте NTLM — тогда укажите домен\пользователь в ADO_PAT
# ADO_PAT=DOMAIN\username:password

# ------------------------------------------------------------
# Проекты для анализа (обязательно)
# ------------------------------------------------------------
# Один или несколько проектов через запятую.
# Пример: ADO_PROJECTS=MyProject,AnotherProject,ThirdProject
ADO_PROJECTS=YourProject

# ------------------------------------------------------------
# Участники команды (необязательно)
# ------------------------------------------------------------
# Если не указано — будут собраны данные по всем авторам.
# Можно указать email или отображаемое имя через запятую.
# Пример: ADO_TEAM_MEMBERS=ivan@company.ru,maria@company.ru,Алексей Сидоров
ADO_TEAM_MEMBERS=

# ------------------------------------------------------------
# Период анализа (обязательно)
# ------------------------------------------------------------
# Формат дат: YYYY-MM-DD
DATE_FROM=2024-01-01
DATE_TO=2024-03-31

# ------------------------------------------------------------
# Версия REST API (необязательно)
# ------------------------------------------------------------
# По умолчанию 7.1 (Azure DevOps Server 2022 и Azure DevOps Services).
# Если ваш сервер старше — укажите 7.0:
#   ADO Server 2022        → 7.1 (по умолчанию)
#   ADO Server 2020/2019   → попробуйте 7.0, если не работает —
#                            может потребоваться ещё более старая версия
# ADO_API_VERSION=7.0
